{
  "manifest_version": 3,
  "name": "SCOUT — Candidate Fit Scorer",
  "version": "1.0",
  "description": "AI-powered fit scores on Dice.com and LinkedIn. Push candidates to SCOUT with one click.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://www.dice.com/*",
    "https://www.linkedin.com/*",
    "https://navitas-ai-platform.wonderfulfield-ebc060c9.eastus.azurecontainerapps.io/*",
    "https://www.signalhire.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.dice.com/*"],
      "js": ["content_scripts/dice.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content_scripts/linkedin.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SCOUT"
  }
}
