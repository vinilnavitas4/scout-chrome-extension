{
  "manifest_version": 3,
  "name": "SCOUT — Candidate Fit Scorer",
  "version": "1.0",
  "description": "AI-powered fit scores on LinkedIn. Push candidates to SCOUT with one click.",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://navitas-ai-platform.wonderfulfield-ebc060c9.eastus.azurecontainerapps.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content_scripts/linkedin.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_title": "SCOUT"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  }
}
