{
  "manifest_version": 3,
  "name": "SCOUT — Candidate Fit Scorer",
  "version": "1.0",
  "description": "AI-powered fit scores on LinkedIn. Push candidates to SCOUT with one click.",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel", "offscreen", "cookies"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.dice.com/*",
    "https://api.jazz.co/*",
    "https://navitas-ai-platform.wonderfulfield-ebc060c9.eastus.azurecontainerapps.io/*",
    "https://huggingface.co/*",
    "https://cdn-lfs.huggingface.co/*",
    "https://cdn-lfs-us-1.huggingface.co/*",
    "https://cdn.jsdelivr.net/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://www.dice.com/*"],
      "js": ["content_scripts/floating_button.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content_scripts/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.dice.com/*"],
      "js": ["lib/pdf.min.js", "content_scripts/dice.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/pdf.worker.min.js"],
      "matches": ["https://www.dice.com/*"]
    }
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_title": "SCOUT"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  }
}
